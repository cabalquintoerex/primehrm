# LGU PRIME-HRM — production server env  →  copy to  server/.env  on the box
# ---------------------------------------------------------------------------
# NEVER commit the real .env. Generate fresh secrets on the server:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------------

# MySQL — the dedicated database/user created in deploy/create-db.sql.
# URL-encode any special characters in the password.
DATABASE_URL="mysql://eprime:CHANGE_ME_STRONG_PASSWORD@localhost:3306/eprime"

# Auth secrets — REPLACE both with freshly generated 64-char hex strings.
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_A_DIFFERENT_64_HEX_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Backend port — must match the nginx proxy_pass (5010) and be free on the box.
PORT=5010

NODE_ENV=production

# The browser origin the app is served from. Same-origin (frontend + proxied API
# both under apps.cebu.gov.ph), so this is the scheme+host only — no /llcprime path.
# The box has a Let's Encrypt cert for apps.cebu.gov.ph and force-redirects HTTP→HTTPS.
CORS_ORIGIN=https://eprime.sytes.net

# Dedicated subdomain served at root, so '/'. (Cookies are scoped to the host
# eprime.sytes.net anyway; other projects are on different hostnames/paths.)
COOKIE_PATH=/

# Cookie Secure flag. This box serves HTTPS, so true. (Set false only if ever
# served over plain HTTP, else the browser drops the auth cookies.)
COOKIE_SECURE=true
